# Signed-session key. Use at least 32 random characters outside local evaluation.
SESSION_SECRET=replace-with-a-random-secret-at-least-32-characters

# Optional absolute path for the seven JSON data files. Defaults to ./data.
# DATA_DIR=/absolute/path/to/data

# This MVP does not send email. If email is added later, sandbox senders may
# deliver only to the provider account owner until a real domain is verified.

